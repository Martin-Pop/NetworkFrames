QMainWindow {
    background-color: #FFFFFF;
}

#control_bar QPushButton {
    background-color: #EF8354;
    border-bottom: 3px solid #FFFFFF;
    padding: 5px 12px;
    font-size: 15px;
}

#control_bar QPushButton::hover {
    background-color: #8C4C31;
}

#control_bar QPushButton[selected="true"] {
    border-bottom: 3px solid #8C4C31;
}

QStackedWidget {
    border: 1px solid #BFC0C0;
    background-color: #C1C1C1;
}

QLabel {
    padding: 20px;
    color: red;
}
/* COMMON */
* {
    font-family: Arial, sans-serif;
    font-size: 15px;
}

QPushButton[styleClass~='common_button'] {
    background-color: #EF8354;
    border-radius: 2px;
    padding: 4px 6px;
}


/* ---- EDITOR PAGE ----*/

/* stack */

QLabel#frame_id_label {
    font-size: 13px;
    font-weight: bold;
    color: #2D3142;
    padding: 0px
}

QFrame#protocol_stack_widget {
    border: 2px solid #4F5D75
}

QPushButton#protocol_stack_edit_button {
    background-color: #4F5D75;
    font-size: 13px;
    border-radius: 0px;
    padding: 4px 6px;
}
QPushButton[styleClass~='protocol_stack_button'] {
    background-color: #EF8354;
    border-radius: 2px;
    padding: 4px 6px;
}




QTextEdit#info_widget {
    background-color: #BFC0C0;
    border: none;
    color: #FFFFFF;
    placeholder-text-color: #FFFFFF
}

